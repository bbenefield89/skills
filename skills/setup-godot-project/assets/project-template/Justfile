# setup-godot-project:template=justfile;version=2;section=godot-validation
set windows-shell := ["powershell.exe", "-NoLogo", "-NoProfile", "-Command"]

godot_repository_executable := "godot"
godot_executable := env_var_or_default("GODOT", godot_repository_executable)
invoke := if os() == "windows" { "&" } else { "" }

import:
    {{ invoke }} "{{ godot_executable }}" --path . --headless --import --quit

test test_path:
    {{ invoke }} "{{ godot_executable }}" --path . --headless --script addons/gut/gut_cmdln.gd -- -gtest res://{{ test_path }} -gexit

test-all:
    {{ invoke }} "{{ godot_executable }}" --path . --headless --script addons/gut/gut_cmdln.gd -- -gdir res://tests -gexit

runtime:
    {{ invoke }} "{{ godot_executable }}" --path . --headless --script tests/verify_runtime.gd

validate: import test-all runtime
